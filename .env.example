# Copy to .env and fill in. Never commit the real .env.

# --- Required in production ---
SECRET_KEY=generate-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourusername.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com

# --- Database ---
# Leave DATABASE_URL unset to use SQLite (default, fine for PythonAnywhere free).
# For PostgreSQL later:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Uploads (MB) ---
MAX_EXCEL_UPLOAD_MB=5
MAX_EXCEL_UNCOMPRESSED_MB=50
MAX_EXCEL_PARSED_ROWS=5000
MAX_PDF_UPLOAD_MB=10
MAX_IMAGE_UPLOAD_MB=5

# --- Storage backend: "local" now; "s3" reserved for a future backend ---
MEDIA_STORAGE_BACKEND=local
# PRIVATE_MEDIA_ROOT=/home/yourusername/pt-app-private-media

# --- Optional tuning ---
# TIME_ZONE=America/Phoenix
# DEFAULT_E1RM_FORMULA=epley        # or brzycki
# LOGIN_RATE_LIMIT_ATTEMPTS=8
# LOGIN_RATE_LIMIT_WINDOW_MINUTES=10
# TRUST_X_FORWARDED_FOR=False       # enable only behind a proxy that overwrites this header
# UPLOAD_RATE_LIMIT_PER_HOUR=20
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=coach@example.com

# --- Future integrations (disabled by default) ---
GOOGLE_CALENDAR_ENABLED=False
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://yourusername.pythonanywhere.com/calendar/google/callback/
# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY=
SITE_URL=https://yourusername.pythonanywhere.com
